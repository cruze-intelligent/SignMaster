{
  "name": "signmaster-usl",
  "version": "1.0.0",
  "description": "Interactive educational game for learning Uganda Sign Language with gamification, badges, and certification",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node tools/optimize-images.js",
    "build": "vite build",
    "preview": "vite preview",
    "map-assets": "node tools/asset-mapper.js",
    "optimize-images": "node tools/optimize-images.js",
    "audit": "node tools/audit-manifest.cjs",
    "content-review:seed": "node tools/sync-content-review.cjs seed",
    "content-review:export": "node tools/sync-content-review.cjs export",
    "content-review:import": "node tools/sync-content-review.cjs import",
    "deploy": "npm run build && gh-pages -d dist",
    "test": "vitest run"
  },
  "keywords": [
    "sign-language",
    "education",
    "gamification",
    "uganda",
    "accessibility",
    "pwa"
  ],
  "author": "Cruze Tech (cruze-tech.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cruze-tech/SignMaster"
  },
  "homepage": "https://games.cruze-tech.com/signmaster",
  "dependencies": {
    "csv-parse": "^6.1.0",
    "gsap": "^3.12.5",
    "howler": "^2.2.4",
    "idb": "^8.0.0",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "csv-writer": "^1.6.0",
    "gh-pages": "^6.1.1",
    "sharp": "^0.33.0",
    "tesseract.js": "^5.1.1",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.1.0",
    "vitest": "^4.0.18"
  }
}
